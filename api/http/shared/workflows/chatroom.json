{
  "openapi": "3.0.3",
  "info": {
    "title": "ChatRoom Workflow Type",
    "description": "ChatRoomWorkflowSpec schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ChatRoomWorkflowHistorySpec": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "ttl": {
            "type": "string",
            "description": "Unified retention duration for chat history entries and their assets."
          }
        }
      },
      "ChatRoomWorkflowTranscriptSpec": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether gear audio should be transcribed and written as text in workspace history."
          },
          "asr_model": {
            "type": "string",
            "description": "RuntimeProfile ASR Model alias resolved when the Workspace reloads."
          }
        }
      },
      "ChatRoomWorkflowSpec": {
        "type": "object",
        "required": [
          "history"
        ],
        "additionalProperties": false,
        "properties": {
          "history": {
            "$ref": "#/components/schemas/ChatRoomWorkflowHistorySpec"
          },
          "transcript": {
            "$ref": "#/components/schemas/ChatRoomWorkflowTranscriptSpec"
          }
        }
      }
    }
  }
}
