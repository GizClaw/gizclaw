{
  "openapi": "3.0.3",
  "info": {
    "title": "Tool Resource Schema",
    "description": "ToolResource envelope schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ToolResource": {
        "type": "object",
        "required": [
          "apiVersion",
          "kind",
          "metadata",
          "spec"
        ],
        "properties": {
          "apiVersion": {
            "$ref": "./resource.json#/components/schemas/ResourceAPIVersion"
          },
          "kind": {
            "type": "string",
            "enum": [
              "Tool"
            ]
          },
          "metadata": {
            "allOf": [
              {
                "$ref": "./resource.json#/components/schemas/ResourceMetadata"
              }
            ],
            "description": "metadata.name is the stable Tool ID and must not contain a colon."
          },
          "spec": {
            "$ref": "../shared/tool_spec.json#/components/schemas/ToolSpec"
          }
        }
      }
    }
  }
}
