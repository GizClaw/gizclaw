{
  "openapi": "3.0.3",
  "info": {
    "title": "Friend Group Invite Token Resource Schema",
    "description": "FriendGroupInviteTokenResource envelope schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "FriendGroupInviteTokenResource": {
        "type": "object",
        "required": [
          "apiVersion",
          "kind",
          "metadata",
          "spec"
        ],
        "properties": {
          "apiVersion": {
            "$ref": "./resource.json#/components/schemas/ResourceAPIVersion"
          },
          "kind": {
            "type": "string",
            "enum": [
              "FriendGroupInviteToken"
            ]
          },
          "metadata": {
            "allOf": [
              {
                "$ref": "./resource.json#/components/schemas/ResourceMetadata"
              }
            ],
            "description": "metadata.name is the friend group custom ID and must match spec.friend_group_id."
          },
          "spec": {
            "$ref": "#/components/schemas/FriendGroupInviteTokenSpec"
          }
        }
      },
      "FriendGroupInviteTokenSpec": {
        "type": "object",
        "required": [
          "friend_group_id",
          "invite_token",
          "expires_at"
        ],
        "properties": {
          "friend_group_id": {
            "type": "string",
            "minLength": 8,
            "maxLength": 48,
            "pattern": "^[a-z][a-z0-9._-]{6,46}[a-z0-9]$",
            "description": "Friend group custom ID. The invite_token value is not a custom ID."
          },
          "invite_token": {
            "type": "string"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
