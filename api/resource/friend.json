{
  "openapi": "3.0.3",
  "info": {
    "title": "Friend Resource Schema",
    "description": "FriendResource envelope schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "FriendResource": {
        "type": "object",
        "required": [
          "apiVersion",
          "kind",
          "metadata",
          "spec"
        ],
        "properties": {
          "apiVersion": {
            "$ref": "./resource.json#/components/schemas/ResourceAPIVersion"
          },
          "kind": {
            "type": "string",
            "enum": [
              "Friend"
            ]
          },
          "metadata": {
            "$ref": "./resource.json#/components/schemas/ResourceMetadata"
          },
          "spec": {
            "$ref": "#/components/schemas/FriendSpec"
          }
        }
      },
      "FriendSpec": {
        "type": "object",
        "required": [
          "owner_public_key",
          "peer_public_key"
        ],
        "properties": {
          "owner_public_key": {
            "type": "string",
            "description": "Canonical owner peer public key. metadata.name must be the sorted relation id owner:peer."
          },
          "peer_public_key": {
            "type": "string",
            "description": "Canonical friend peer public key. Applying the resource creates both owner-view rows."
          }
        }
      }
    }
  }
}
