{
  "openapi": "3.0.3",
  "info": {
    "title": "Firmware Artifact Type",
    "description": "Firmware channel artifact metadata schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "FirmwareArtifact": {
        "type": "object",
        "required": [
          "tar_path",
          "manifest_path",
          "files_path",
          "sha256",
          "size",
          "content_type",
          "uploaded_at"
        ],
        "additionalProperties": false,
        "properties": {
          "tar_path": {
            "type": "string",
            "description": "Server-owned objectstore path for the uploaded artifact.tar.",
            "example": "firmware/devkit/stable/artifact.tar"
          },
          "manifest_path": {
            "type": "string",
            "description": "Server-owned objectstore path for the artifact manifest.",
            "example": "firmware/devkit/stable/manifest.json"
          },
          "files_path": {
            "type": "string",
            "description": "Server-owned objectstore prefix for extracted artifact files.",
            "example": "firmware/devkit/stable/files/"
          },
          "sha256": {
            "type": "string",
            "description": "SHA-256 digest of the uploaded artifact.tar."
          },
          "size": {
            "type": "integer",
            "format": "int64",
            "description": "Uploaded artifact.tar size in bytes."
          },
          "content_type": {
            "type": "string",
            "description": "Content type for the uploaded artifact.tar.",
            "example": "application/x-tar"
          },
          "uploaded_at": {
            "type": "string",
            "format": "date-time",
            "description": "Server-owned upload timestamp."
          }
        }
      }
    }
  }
}
