{
  "openapi": "3.0.3",
  "info": {
    "title": "Firmware Spec Type",
    "description": "Firmware spec schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "FirmwareSpecSlot": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "version": {
            "type": "string",
            "description": "Version carried by this slot.",
            "example": "1.0.3"
          },
          "description": {
            "type": "string",
            "example": "Devkit firmware 1.0.3"
          }
        }
      },
      "FirmwareSpecSlots": {
        "type": "object",
        "required": [
          "stable",
          "beta",
          "develop",
          "pending"
        ],
        "additionalProperties": false,
        "properties": {
          "stable": {
            "$ref": "#/components/schemas/FirmwareSpecSlot"
          },
          "beta": {
            "$ref": "#/components/schemas/FirmwareSpecSlot"
          },
          "develop": {
            "$ref": "#/components/schemas/FirmwareSpecSlot"
          },
          "pending": {
            "$ref": "#/components/schemas/FirmwareSpecSlot"
          }
        }
      },
      "FirmwareSpec": {
        "type": "object",
        "required": [
          "slots"
        ],
        "additionalProperties": false,
        "properties": {
          "description": {
            "type": "string",
            "example": "Devkit firmware line"
          },
          "slots": {
            "$ref": "#/components/schemas/FirmwareSpecSlots"
          }
        }
      }
    }
  }
}
