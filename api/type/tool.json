{
  "openapi": "3.0.3",
  "info": {
    "title": "Tool Type",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "Tool": {
        "type": "object",
        "required": [
          "id",
          "source",
          "enabled",
          "input_schema",
          "executor",
          "created_at",
          "updated_at"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "source": {
            "$ref": "./tool_source.json#/components/schemas/ToolSource"
          },
          "enabled": {
            "type": "boolean"
          },
          "owner_peer": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "input_schema": {
            "$ref": "./tool_json_schema.json#/components/schemas/ToolJSONSchema"
          },
          "output_schema": {
            "$ref": "./tool_json_schema.json#/components/schemas/ToolJSONSchema"
          },
          "triggers": {
            "type": "array",
            "items": {
              "$ref": "./tool_trigger.json#/components/schemas/ToolTrigger"
            }
          },
          "executor": {
            "$ref": "./tool_executor.json#/components/schemas/ToolExecutor"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
