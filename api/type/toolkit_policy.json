{
  "openapi": "3.0.3",
  "info": {
    "title": "Toolkit Policy Type",
    "description": "Shared Toolkit exposure policy schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ToolkitPolicy": {
        "type": "object",
        "description": "Policy that controls which Toolkit tools are exposed to an agent runtime. Omit tool_ids to inherit the broader policy; set an empty list to expose no tools.",
        "properties": {
          "tool_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true,
            "description": "Allowed persisted Tool IDs."
          }
        },
        "additionalProperties": false
      }
    }
  }
}
