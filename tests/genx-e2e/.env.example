# Copy to tests/genx-e2e/.env for local genx provider e2e runs.
# Keep this file credential-only. Test models, voices, audio formats, and
# fixtures are embedded or hardcoded by the tests.

GIZCLAW_GENX_E2E_DOUBAO_APP_ID=
GIZCLAW_GENX_E2E_DOUBAO_API_KEY=

GIZCLAW_GENX_E2E_MINIMAX_API_KEY=
GIZCLAW_GENX_E2E_MINIMAX_BASE_URL=https://api.minimax.io
GIZCLAW_GENX_E2E_MINIMAX_VOICE_ID=female-shaonv

# OpenAI credential used by the Flowcraft Transformer e2e test.
GIZCLAW_GENX_E2E_FLOWCRAFT_OPENAI_API_KEY=
