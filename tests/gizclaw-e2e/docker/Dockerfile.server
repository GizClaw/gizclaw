ARG BASE_IMAGE=gizclaw-go:linux-amd64-cn-base
FROM ${BASE_IMAGE}

WORKDIR /src

RUN apt-get update \
 && apt-get install -y --no-install-recommends gettext-base \
 && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
COPY apps/wails/frontend/package.json apps/wails/frontend/package.json
COPY js/package.json js/package.json
COPY js/packages/gizclaw/package.json js/packages/gizclaw/package.json
COPY js/packages/pixa/package.json js/packages/pixa/package.json

RUN npm ci

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN find tests/gizclaw-e2e/docker -name '*.sh' -exec chmod +x {} +

ENTRYPOINT ["/src/tests/gizclaw-e2e/docker/entrypoint-server.sh"]
