        "properties": {
          "server_time": {
            "type": "integer",
            "format": "int64"
          },
          "ok": {
            "type": "boolean"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SpeedTestRequest": {
